<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-add-product-name" author="helen">
        <addColumn tableName="loan_product">
            <column name="product_name" type="VARCHAR(225)">
                <constraints nullable="false"></constraints>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-drop-product_name_from_loan" author="helen">
        <dropColumn tableName="loan" columnName="product_name"></dropColumn>
    </changeSet>

    <changeSet id="006-drop-product-name-from-loan-product" author="helen">
        <dropColumn tableName="loan_product" columnName="product_name"/>
    </changeSet>

</databaseChangeLog>     